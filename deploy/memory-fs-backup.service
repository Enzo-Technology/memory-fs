[Unit]
Description=memory-fs database backup to GCS
# Persistent=true on the timer means a missed backup fires on boot; ensure the
# network is up before gsutil tries to reach GCS.
After=network-online.target
Wants=network-online.target

[Service]
Type=oneshot
ExecStart=/opt/memory-fs/deploy/backup.sh
User=memoryfs
Group=memoryfs
# Provides BUCKET and DB (and any other vars shared with the main service).
EnvironmentFile=/etc/memory-fs/env
