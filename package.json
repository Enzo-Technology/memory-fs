    "better-auth": "^1.6.13",
    "better-sqlite3": "^12.10.0",
    "jose": "^6.2.3",
    "react": "^19.2.6",
    "react-dom": "^19.2.6",
    "zod": "^4.4.3"
  },
  "devDependencies": {
    "@anthropic-ai/sdk": "^0.30.1",
    "@types/better-sqlite3": "^7.6.11",
    "@types/node": "^22.7.4",
    "@vitejs/plugin-react": "^6.0.2",
    "tsx": "^4.19.1",
    "typescript": "^5.6.2",
    "vite": "^8.0.16",
    "vitest": "^4.1.8"
  }
