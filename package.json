{
  "name": "memory-fs",
  "version": "0.1.0",
  "description": "Shared memory filesystem exposed over MCP",
  "type": "module",
  "bin": {
    "memory-fs": "dist/index.js"
  },
  "files": [
    "dist"
  ],
  "scripts": {
    "build": "tsc && mkdir -p dist/lib/ui && cp src/lib/ui/*.html src/lib/ui/*.js dist/lib/ui/",
    "start": "node dist/index.js",
    "dev": "tsx --env-file=.env src/index.ts",
    "test": "vitest run",
    "test:watch": "vitest",
    "ui": "node dist/ui-server.js",
    "ui:dev": "tsx src/ui-server.ts",
    "ui:secure": "infisical run -- node dist/ui-server.js"
  },
  "dependencies": {
    "@better-auth/oauth-provider": "^1.6.13",
    "@modelcontextprotocol/sdk": "^1.0.4",
    "better-auth": "latest",
    "better-sqlite3": "latest",
    "jose": "^6.2.3",
    "zod": "latest"
  },
  "devDependencies": {
    "@anthropic-ai/sdk": "^0.30.1",
    "@types/better-sqlite3": "^7.6.11",
    "@types/node": "^22.7.4",
    "bun-types": "latest",
    "tsx": "^4.19.1",
    "typescript": "^5.6.2"
  }
}
