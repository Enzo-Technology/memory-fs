{
  "name": "memory-fs",
  "version": "0.1.0",
  "description": "Shared memory filesystem exposed over MCP",
  "license": "AGPL-3.0-only",
  "type": "module",
  "engines": {
    "node": ">=20 <25"
  },
  "bin": {
    "memory-fs": "dist/index.js"
  },
  "files": [
    "dist"
  ],
  "scripts": {
    "build": "vite build ui && tsc",
